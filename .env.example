API_KEY=xxxx
SECRET_KEY=xxxx
CA_CERT_PATH=/xxx/xxx/xxx/xxx.pfx
CA_PASSWORD=xxxxxxxxxx

# App
APP_ENV=development
APP_SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
APP_WEBSITE_URL=http://localhost:5173


# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pocketcfo

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3.1-flash-lite

# 永豐金（豐存股）Sinopac API
SINOPAC_API_BASE_URL=https://api.sinotrade.com.tw
SINOPAC_ACCOUNT_ID=your-sinopac-account-id
SINOPAC_API_KEY=your-sinopac-api-key
SINOPAC_API_SECRET=your-sinopac-api-secret
# Path to downloaded broker certificate (.pfx or .p12)
SINOPAC_CERT_PATH=./secrets/Sinopac.pfx
SINOPAC_CERT_PASSWORD=your-cert-password

# 台新證券 Taishin API
TAISHIN_API_BASE_URL=https://api.taishinbank.com.tw
TAISHIN_ACCOUNT_ID=your-taishin-account-id
TAISHIN_API_KEY=your-taishin-api-key
TAISHIN_API_SECRET=your-taishin-api-secret
TAISHIN_CERT_PATH=./secrets/Taishin.pfx
TAISHIN_CERT_PASSWORD=your-cert-password

# File Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# CORS (React dev server)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Transfer Detection
# Accounts owned by you — transfers between these are excluded from income statement
INTERNAL_ACCOUNT_IDS=["ACC001","ACC002","ACC003"]

# SMTP Mail Settings (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_SENDER=your-email@gmail.com